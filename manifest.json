{
  "manifest_version": 3,
  "name": "TabHiber",
  "short_name": "TabHiber",
  "version": "0.1.0",
  "description": "Hibernate tab groups locally. Zero telemetry. Zero account. Audit-ready in a single popup file.",
  "permissions": ["tabs", "tabGroups", "storage", "activeTab"],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "TabHiber — Hibernate tabs"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "commands": {
    "hibernate-current-window": {
      "suggested_key": { "default": "Ctrl+Shift+H", "mac": "Command+Shift+H" },
      "description": "Hibernate the current window into a new group"
    }
  },
  "icons": {
    "16": "src/icons/icon16.png",
    "48": "src/icons/icon48.png",
    "128": "src/icons/icon128.png"
  },
  "minimum_chrome_version": "120"
}
